{
  "name": "lucidlink-assignment",
  "version": "2.0.0",
  "description": "Georgi Marinov's solution to the LucidLink technical home assignment task.",
  "main": "index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest",
    "build": "tsup",
    "dev": "tsup && node ./dist/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypermarinov/lucidlink-assignment.git"
  },
  "author": "Georgi Marinov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hypermarinov/lucidlink-assignment/issues"
  },
  "homepage": "https://github.com/hypermarinov/lucidlink-assignment#readme",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
